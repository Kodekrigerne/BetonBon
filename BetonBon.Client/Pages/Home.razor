@page "/"

<style>
    .home-container { display: flex; flex-direction: column; height: 100%; background-color: #f9fafb; font-family: sans-serif; }
    
    /* Header */
    .header { background-color: white; padding: 1rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e5e7eb; box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); flex-shrink: 0; }
    .header-profile { display: flex; align-items: center; gap: 1rem; }
    .avatar { width: 3rem; height: 3rem; background-color: #2563eb; color: white; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: bold; font-size: 1.125rem; }
    .header-info h1 { margin: 0; font-size: 1rem; font-weight: bold; color: #111827; }
    .header-info p { margin: 0; font-size: 0.875rem; color: #6b7280; font-weight: 500; }
    .icon-btn { padding: 0.75rem; color: #6b7280; background-color: #f3f4f6; border-radius: 50%; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    
    /* Content */
    .content { flex: 1; padding: 1.25rem; overflow-y: auto; display: flex; flex-direction: column; gap: 1.5rem; }
    .welcome h2 { margin: 0 0 0.25rem 0; font-size: 1.5rem; font-weight: bold; color: #1f2937; }
    .welcome p { margin: 0; color: #4b5563; font-size: 1rem; }
    
    /* Project Button */
    .project-btn { width: 100%; background-color: white; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 2px solid #dbeafe; display: flex; align-items: center; gap: 1.25rem; text-align: left; cursor: pointer; transition: transform 0.1s; }
    .project-btn:active { transform: scale(0.98); background-color: #eff6ff; }
    .project-icon { width: 4rem; height: 4rem; background-color: #2563eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .project-text h2 { margin: 0 0 0.25rem 0; font-size: 1.25rem; font-weight: bold; color: #111827; }
    .project-text p { margin: 0; color: #4b5563; font-size: 1rem; }
    
    /* Stopwatch Card */
    .stopwatch-card { background-color: white; padding: 1.5rem; border-radius: 1rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 2px solid #f3f4f6; text-align: center; }
    .stopwatch-icon { display: flex; justify-content: center; margin-bottom: 0.5rem; color: #6b7280; }
    .stopwatch-title { margin: 0; font-size: 1.125rem; font-weight: bold; color: #1f2937; text-transform: uppercase; letter-spacing: 0.05em; }
    .stopwatch-time { font-family: monospace; font-size: 3rem; font-weight: 900; color: #111827; margin: 1.25rem 0; letter-spacing: -0.025em; font-variant-numeric: tabular-nums; }
    
    /* Timer Buttons */
    .timer-btn { width: 100%; font-weight: bold; font-size: 1.25rem; border-radius: 0.75rem; padding: 1rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer; border: none; color: white; transition: transform 0.1s; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .timer-btn:active { transform: scale(0.98); }
    .btn-green { background-color: #22c55e; }
    .btn-green:active { background-color: #16a34a; }
    .btn-yellow { background-color: #eab308; }
    .btn-yellow:active { background-color: #ca8a04; }
    .btn-red { background-color: #ef4444; }
    .btn-red:active { background-color: #dc2626; }
    .btn-group { display: flex; gap: 0.75rem; }
    .btn-group .timer-btn { flex: 1; }
</style>

<div class="home-container">
    @* Header *@
    <div class="header">
        <div class="header-profile">
            <div class="avatar">HE</div>
            <div class="header-info">
                <h1>Holmsgaard Entreprenør</h1>
                <p>CVR: 1728451 NH</p>
            </div>
        </div>
        <button class="icon-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path>
                <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path>
            </svg>
        </button>
    </div>

    @* Content *@
    <div class="content">
        <div class="welcome">
            <h2>Velkommen tilbage</h2>
            <p>Hvad vil du registrere i dag?</p>
        </div>

        <button class="project-btn">
            <div class="project-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"></path>
                </svg>
            </div>
            <div class="project-text">
                <h2>Mine Projekter</h2>
                <p>Vælg projekt for at registrere tid og materialer</p>
            </div>
        </button>

        @* Stopwatch Section *@
        <div class="stopwatch-card">
            <div class="stopwatch-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <h2 class="stopwatch-title">Tidsregistrering</h2>
            
            <div class="stopwatch-time">
                    0
@*                 @FormatTime(elapsedSeconds)
 *@            </div>
            
            @if (timerState == TimerState.Idle)
            {
                <button class="timer-btn btn-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                    Start tid
                </button>
            }
            else if (timerState == TimerState.Running)
            {
                <div class="btn-group">
                    <button class="timer-btn btn-yellow">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="14" y="4" width="4" height="16" rx="1"></rect><rect x="6" y="4" width="4" height="16" rx="1"></rect></svg>
                        Pause
                    </button>
                    <button class="timer-btn btn-red">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect></svg>
                        Stop & Gem
                    </button>
                </div>
            }
            else if (timerState == TimerState.Paused)
            {
                <div class="btn-group">
                    <button class="timer-btn btn-green">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                        Genoptag
                    </button>
                    <button class="timer-btn btn-red">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"></rect></svg>
                        Stop & Gem
                    </button>
                </div>
            }
        </div>

        @* Ny Brugere Knap *@
        <a href="/users" class="project-btn" style="border-color: #e5e7eb; padding: 0.75rem 1.25rem; text-decoration: none; display: flex; box-sizing: border-box; width: 100%;">
    <div class="project-icon" style="background-color: #4b5563; width: 2.5rem; height: 2.5rem; flex-shrink: 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
    </div>
    <div class="project-text">
        <h2 style="font-size: 1rem; margin: 0;">Brugere</h2>
        <p style="font-size: 0.875rem; margin: 0;">Administrer medarbejdere</p>
    </div>
</a>

    </div>
</div>

@code {
    [Inject]
    public NavigationManager Navigation { get; set; } = default!;

    private enum TimerState { Idle, Running, Paused }
    private TimerState timerState = TimerState.Idle;
    private int elapsedSeconds = 0;
    private System.Threading.Timer? timer;

}