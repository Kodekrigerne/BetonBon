@using BetonBon.Client.Shared.ViewModels


<div class="user-card">
    <div class="user-avatar">
        @GetInitials(User.Name)
    </div>
    <div class="user-info">
        <h3>@User.Name</h3>
        <p>@User.Role</p>
    </div>
    <button class="back-btn" @onclick="() => OnEditRequested.InvokeAsync(User.Id)">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
        </svg>
    </button>
</div>

@code {
    [Parameter] public UserViewModel User { get; set; } = null!;
    [Parameter] public EventCallback<Guid> OnEditRequested { get; set; }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(' ');
        return parts.Length > 1
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name[0].ToString().ToUpper();
    }
}