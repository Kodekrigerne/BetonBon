@using BetonBon.Shared.Models
<button @onclick="@SelectProject" class="project-item">
    <div>
        <div class="project-number">Projekt nr. @Project.Number</div>
        <div class="project-name">@Project.Name</div>
    </div>
    <div class="chevron-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"></path>
        </svg>
    </div>
</button>

@code {

    [Parameter, EditorRequired]
    public ProjectDTO Project { get; set; }

    [Parameter]
    public EventCallback<ProjectDTO> ProjectSelected { get; set; }

    private async Task SelectProject() => await ProjectSelected.InvokeAsync(Project);

}

<style>
.project-item {
width: 100%;
text-align: left;
padding: 1.25rem;
background-color: white;
border-radius: 0.75rem;
box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
border: 1px solid #e5e7eb;
display: flex;
align-items: center;
justify-content: space-between;
cursor: pointer;
transition: background-color 0.1s, border-color 0.1s;
}

.project-item:active {
background-color: #eff6ff;
border-color: #bfdbfe;
}

.project-number {
font-size: 0.875rem;
font-weight: bold;
color: #2563eb;
margin-bottom: 0.25rem;
}

.project-name {
font-weight: bold;
font-size: 1.125rem;
color: #111827;
margin: 0;
}

    .chevron-wrapper {
        width: 2.5rem;
        height: 2.5rem;
        background-color: #f9fafb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
    }

</style>