@inject ProjectService _projectFetcher

<div class="projects-container">

    @* Search Field *@

    <div class="search-area">
        <div class="search-wrapper">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input type="text"
                   placeholder="Søg på navn eller nummer..."
                   @bind="SearchTerm"
                   @bind:event="oninput"
                   class="search-input" />
        </div>
    </div>

    @* Project List *@
    <div class="project-list">
        @foreach (var project in FilteredProjects)
        {
            <ProjectCard ProjectName="@project.Name" ProjectNumber="@project.Number"></ProjectCard>
        }
    </div>
</div>

@code {
    private string SearchTerm { get; set; } = "";

    private List<ProjectDTO> Projects = new List<ProjectDTO>();

    private IEnumerable<ProjectDTO> FilteredProjects =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? Projects
            : Projects.Where(p =>
                p.Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Number.ToString().Contains(SearchTerm));


    protected override async Task OnInitializedAsync()
    {
        Projects = await GetProjects();
    }

    private void SelectProject(ProjectDTO project)
    {
        // Her ville man typisk gemme det valgte projekt i en AppState service
        // og derefter navigere til aktivitets-vælgeren eller handlingsmenuen
        // Navigation.NavigateTo("/activities");
    }

    private async Task<List<ProjectDTO>> GetProjects()
    {
        return await _projectFetcher.GetAllProjectsAsync();
    }
}

<style>
    .projects-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #f9fafb;
        font-family: sans-serif;
    }

    /* Header */
    .header {
        background-color: white;
        padding: 1rem;
        display: flex;
        align-items: center;
        border-bottom: 1px solid #e5e7eb;
        box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
        flex-shrink: 0;
    }

    .back-btn {
        padding: 0.5rem;
        margin-left: -0.5rem;
        color: #2563eb;
        background-color: #eff6ff;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        border: none;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    
        .back-btn:active {
            background-color: #dbeafe;
        }

    .back-btn-text {
        font-weight: bold;
        margin-left: 0.25rem;
        font-size: 1.125rem;
    }

    .header-title {
        flex: 1;
        text-align: center;
        font-weight: bold;
        font-size: 1.25rem;
        padding-right: 5rem; /* For at centrere titlen når tilbage-knappen er der */
        margin: 0;
        color: #111827;
    }

    /* Info Banner (brugt efter stopur) */
    .info-banner {
        background-color: #eff6ff;
        padding: 1rem;
        border-bottom: 1px solid #dbeafe;
        flex-shrink: 0;
    }

    .info-banner-text {
        font-size: 0.875rem;
        color: #1e40af;
        font-weight: 500;
        margin: 0;
    }

    /* Search Area */
    .search-area {
        padding: 1rem;
        background-color: white;
        border-bottom: 1px solid #f3f4f6;
        flex-shrink: 0;
    }

    .search-wrapper {
        position: relative;
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
    }

    .search-input {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        background-color: #f3f4f6;
        border: 2px solid transparent;
        border-radius: 0.75rem;
        font-size: 1.125rem;
        font-weight: 500;
        color: #111827;
        outline: none;
        transition: background-color 0.2s, border-color 0.2s;
        box-sizing: border-box;
    }

        .search-input:focus {
            background-color: white;
            border-color: #3b82f6;
        }

        .search-input::placeholder {
            color: #6b7280;
        }

    /* Project List */
    .project-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
</style>