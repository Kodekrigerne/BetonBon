@page "/users"

@inject IQueryDispatcher 

<style>
    .users-container { display: flex; flex-direction: column; height: 100%; background-color: #f9fafb; font-family: sans-serif; }
    
    /* Header & Navigation */
    .header { background-color: white; padding: 1rem; display: flex; align-items: center; gap: 1rem; border-bottom: 1px solid #e5e7eb; }
    .back-btn { background: none; border: none; color: #6b7280; cursor: pointer; padding: 0.5rem; display: flex; align-items: center; }
    .header h1 { margin: 0; font-size: 1.25rem; font-weight: bold; color: #111827; }

    /* Content Area */
    .content { flex: 1; padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }

    /* Create Button */
    .create-btn { 
        background-color: #2563eb; color: white; border: none; padding: 1rem; 
        border-radius: 0.75rem; font-weight: bold; font-size: 1rem; 
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        cursor: pointer; width: 100%; box-shadow: 0 2px 4px rgba(37, 99, 235, 0.2);
    }

    /* User List */
    .user-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .user-card { 
        background-color: white; padding: 1rem; border-radius: 0.75rem; 
        border: 1px solid #e5e7eb; display: flex; align-items: center; gap: 1rem;
    }
    .user-avatar { 
        width: 2.5rem; height: 2.5rem; background-color: #f3f4f6; color: #4b5563; 
        border-radius: 50%; display: flex; align-items: center; justify-content: center; 
        font-weight: bold; font-size: 0.875rem; 
    }
    .user-info { flex: 1; }
    .user-info h3 { margin: 0; font-size: 1rem; color: #111827; }
    .user-info p { margin: 0; font-size: 0.875rem; color: #6b7280; }
</style>

<div class="users-container">
    <div class="header">
        <a href="/" class="back-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h1>Medarbejdere</h1>
    </div>

    <div class="content">
        @* Opret Bruger Knap *@
        <button class="create-btn" @onclick="HandleCreateUser">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7v14"/></svg>
            Opret Bruger
        </button>

        @* Oversigt over brugere *@
        <div class="user-list">
            @if (users == null)
            {
                <p>Henter brugere...</p>
            }
            else
            {
                @foreach (var user in users)
                {
                    <div class="user-card">
                        <div class="user-avatar">
                            @GetInitials(user.Name)
                        </div>
                        <div class="user-info">
                            <h3>@user.Name</h3>
                            <p>@user.Role</p>
                        </div>
                        <button class="back-btn" @onclick="() => EditUser(user.Id)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                        </button>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<UserViewModel>? users;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        
    }

    private void HandleCreateUser()
    {
        // Logik til at åbne en modal eller navigere til en opret-side
    }

    private void EditUser(int id)
    {
        // Logik til redigering
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(' ');
        return parts.Length > 1 
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper() 
            : name[0].ToString().ToUpper();
    }

    public class UserViewModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
    }
}