@page "/login"

@attribute [AllowAnonymous]
@layout LoginLayout

<div class="login-container">
    <div class="login-header">
        <div class="login-logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
                <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            </svg>
        </div>
        <h1>Log ind</h1>
        <p>Velkommen til BetonBon</p>
    </div>

    <div class="login-card">
        <div class="input-group">
            <label for="username">Brugernavn</label>
            <input type="text" id="username" class="theme-input" placeholder="Indtast dit brugernavn" />
        </div>

        <div class="input-group">
            <label for="password">Adgangskode</label>
            <input type="password" id="password" class="theme-input" placeholder="Indtast din adgangskode" />
        </div>

        <div class="btn-group">
            <button class="btn-primary">Log ind</button>
            <button class="btn-secondary">Annuller</button>
        </div>
    </div>
</div>

@code {

}
